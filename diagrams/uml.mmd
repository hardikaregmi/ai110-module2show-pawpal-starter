classDiagram
    class Owner {
        +str name
        +list pets
        +add_pet(pet)
        +get_all_tasks()
    }

    class Pet {
        +str name
        +str breed
        +int age
        +list tasks
        +add_task(task)
    }

    class Task {
        +str description
        +str duration
        +str priority
        +str time
        +bool is_completed
        +mark_complete()
    }

    class Scheduler {
        +sort_by_time(tasks)
        +filter_tasks(tasks, criteria)
        +detect_conflicts(tasks)
    }

    Owner "1" --> "*" Pet : manages
    Pet "1" --> "*" Task : has
    Scheduler ..> Task : organizes